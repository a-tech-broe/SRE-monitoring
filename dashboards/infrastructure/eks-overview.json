{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "EKS Infrastructure Overview",
  "uid": "eks-infrastructure",
  "tags": ["eks", "infrastructure", "aws"],
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU by Node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1 - rate(node_cpu_seconds_total{mode='idle'}[5m])",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Node Memory by Node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Pod Scheduling Capacity",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by(node) (kube_pod_info) / sum by(node) (kube_node_status_allocatable{resource='pods'})",
          "legendFormat": "{{ node }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 }
    }
  ]
}

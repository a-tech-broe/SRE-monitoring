{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "Kubernetes Cluster Overview",
  "uid": "k8s-cluster-overview",
  "tags": ["kubernetes", "cluster"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cluster CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode='idle'}[5m]))",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Cluster Memory Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1 - (sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Node Count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "count(kube_node_status_condition{condition='Ready',status='true'})", "legendFormat": "Ready" },
        { "expr": "count(kube_node_status_condition{condition='Ready',status='false'})", "legendFormat": "Not Ready" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "title": "Pod Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(kube_pod_status_phase{phase='Running'})", "legendFormat": "Running" },
        { "expr": "sum(kube_pod_status_phase{phase='Pending'})", "legendFormat": "Pending" },
        { "expr": "sum(kube_pod_status_phase{phase='Failed'})", "legendFormat": "Failed" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "title": "CPU Usage by Namespace",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by(namespace) (rate(container_cpu_usage_seconds_total{container!='',container!='POD'}[5m]))",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 6,
      "title": "Memory Usage by Namespace",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by(namespace) (container_memory_working_set_bytes{container!='',container!='POD'})",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 }
    }
  ]
}

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars.backup
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Terraform sensitive var files — use AWS Secrets Manager or SOPS instead
*.auto.tfvars
!terraform/environments/*/terraform.tfvars

# Helm
charts/
*.tgz

# Kubernetes secrets — never commit plaintext secrets
*-secret.yaml
*-secrets.yaml
secrets.yaml

# SOPS encrypted files are safe to commit; decrypted are not
*.dec.yaml
*.decrypted.yaml

# kubeconfig
kubeconfig
kubeconfig.*
.kube/

# AWS credentials
.aws/
credentials

# Local env overrides
.env
.env.*
.envrc
!.env.example

# OS artifacts
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp
*.swo
*~

# Build outputs
dist/
build/
bin/

# Pre-commit cache
.pre-commit-cache/

# Python (scripts)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Logs
*.log

# Temporary
*.tmp
*.bak

/terraform/                     @your-org/sre-team @your-org/infra-leads

# Production manifests require additional approval
/kubernetes/overlays/prod/      @your-org/sre-team @your-org/infra-leads

# Alert rules require SRE on-call lead review
/alerts/                        @your-org/sre-oncall

# Dashboard changes require SRE team review
/dashboards/                    @your-org/sre-team

# CI/CD pipeline changes require infra-lead approval
/.github/workflows/             @your-org/infra-leads

# Docs can be merged by any SRE
/docs/                          @your-org/sre-team
